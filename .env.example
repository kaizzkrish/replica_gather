# --- PRODUCTION SETTINGS for AWS ---
# Change these values to your actual AWS URLs/IPs

# Common Settings
DATABASE_URL=postgres://postgres:postgres@db:5432/replica_gather

# Server (Socket.IO)
SERVER_PORT=3001
# Allow the client to connect
CORS_ORIGINS=http://your-aws-client-url.com

# Client (React)
CLIENT_PORT=80
# The frontend needs to know where the server is
VITE_API_URL=http://your-aws-server-ip:3001
